# Copy to .env.local for local development (never commit .env.local).
# For Cloudflare Workers, the build copies these into dist/server/.dev.vars —
# also set the same variables in your host dashboard (e.g. Cloudflare Pages/Workers secrets).

VITE_SUPABASE_URL=https://your-project.supabase.co

# Use either the anon key or the newer publishable key from Supabase → Project Settings → API
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Alternative name supported by this app (same value as VITE_SUPABASE_ANON_KEY):
# VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
